  "keyFeatures": [
    "Custom Elements-based WYSIWYG editor (<trix-editor> and <trix-toolbar>)",
    "Sophisticated internal document model (not contenteditable/execCommand dependent)",
    "File and image attachment support with upload progress tracking",
    "Programmatic editing API (insert, delete, format text)",
    "Unlimited undo/redo with state serialization",
    "HTML sanitization via DOMPurify",
    "Form integration with Element Internals and constraint validation",
    "Inline (bold, italic, strike, href) and block (heading, quote, code, lists) attributes",
    "Custom toolbar and custom action support",
    "ESM and UMD distribution formats"
  ],
